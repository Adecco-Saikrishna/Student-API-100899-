            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My New Product\",\n  \"description\": \"This is a product created for practice.\",\n  \"price\": 499.99,\n  \"discountPercentage\": 10,\n  \"rating\": 4.5,\n  \"stock\": 100,\n  \"brand\": \"PracticeBrand\",\n  \"category\": \"smartphones\",\n  \"thumbnail\": \"https://via.placeholder.com/300\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
