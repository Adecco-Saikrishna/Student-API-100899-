<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Royal Shopping Mall</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
    }

    body{
        background:#f4f4f4;
        padding:20px;
    }

    h1{
        text-align:center;
        margin-bottom:30px;
        color:#333;
    }

    .container{
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
        gap:20px;
    }

    .card{
        background:white;
        border-radius:10px;
        box-shadow:0 2px 8px rgba(0,0,0,0.1);
        overflow:hidden;
        text-align:center;
        padding-bottom:15px;
    }

    .card img{
        width:100%;
        height:250px;
        object-fit:cover;
    }

    .card h3{
        margin:10px 0;
        color:#333;
    }

    .price{
        color:green;
        font-size:18px;
        font-weight:bold;
        margin-bottom:10px;
    }

    .btn-group{
        display:flex;
        justify-content:center;
        gap:10px;
    }

    .btn{
        background:blue;
        color:white;
        border:none;
        padding:10px 15px;
        border-radius:5px;
        cursor:pointer;
        font-size:14px;
    }

    .btn:hover{
        background:#0047ab;
    }
</style>
</head>
<body>

<h1>Royal Shopping Mall</h1>

<div class="container">

    <div class="card">
        <img src="https://via.placeholder.com/250x250" alt="Dress 1">
        <h3>Floral Dress</h3>
